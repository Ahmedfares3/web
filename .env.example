# Database
DATABASE_URL="postgresql://username:password@localhost:5432/affiliate_souk_egypt"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# JWT
JWT_SECRET="your-jwt-secret-here"

# Email Configuration (for notifications and password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
FROM_EMAIL="noreply@affiliatesouk.eg"

# File Upload
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE="5242880" # 5MB

# Payment Gateways
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox" # or "live"

# Fawry Payment Gateway
FAWRY_MERCHANT_CODE="your-fawry-merchant-code"
FAWRY_SECURITY_KEY="your-fawry-security-key"
FAWRY_BASE_URL="https://atfawry.fawrystaging.com" # or production URL

# Social Media APIs (for campaign tracking)
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# Analytics
GOOGLE_ANALYTICS_ID="your-ga-id"

# Rate Limiting
RATE_LIMIT_WINDOW="900000" # 15 minutes in milliseconds
RATE_LIMIT_MAX="100" # max requests per window

# Security
BCRYPT_ROUNDS="12"
SESSION_TIMEOUT="86400000" # 24 hours in milliseconds

# Chat System
SOCKET_IO_PORT="3001"

# Admin Settings
ADMIN_EMAIL="admin@affiliatesouk.eg"
SUPPORT_EMAIL="support@affiliatesouk.eg"

# Application Settings
APP_NAME="أفلييت سوق مصر"
APP_URL="https://affiliatesouk.eg"
APP_LOGO="/images/logo.png"

# Backup Settings
BACKUP_ENABLED="true"
BACKUP_SCHEDULE="0 2 * * *" # Daily at 2 AM
BACKUP_RETENTION_DAYS="30"
